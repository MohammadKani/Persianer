{
  "manifest_version": 3,
  "name": "Persianer",
  "version": "2.0.1",
  "description": "پرشینر : تجربه روان فارسی در وب",
  "author": "محمد کنی",
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["profiles.js", "content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "پرشینر : تجربه روان فارسی در وب"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["config.js", "logger.js", "script.js", "profiles.js"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "minimum_chrome_version": "88"
}
